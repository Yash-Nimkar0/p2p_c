# ──────────────────────────────────────────────
# P2P GPU Inference Network — Router Config
# ──────────────────────────────────────────────

# Server
PORT=3000

# Admin secret (used to create/manage API keys)
ADMIN_SECRET=change-this-in-production

# Database
DB_PATH=./data/p2p_gpu.db

# Rate Limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_GLOBAL_RPM=1000

# Request Queue
QUEUE_MAX_SIZE=50
QUEUE_TIMEOUT_MS=30000

# Timeouts
FIRST_TOKEN_TIMEOUT_MS=2000
TOTAL_TIMEOUT_MS=30000
MAX_RETRIES=2

# Heartbeat
HEARTBEAT_CHECK_MS=5000
HEARTBEAT_TIMEOUT_MS=15000

# Logging
LOG_LEVEL=INFO
